# clausroom environment variables (server unless noted).
# Copy to .env and adjust. All variables are optional; defaults shown.

# Interface the server binds to. Keep 127.0.0.1 and expose via `tailscale serve`.
AGENT_ROOM_HOST=127.0.0.1

# Port the server listens on. 0 = pick an ephemeral port (the actual port is
# printed to stdout as "CLAUSROOM_LISTENING <port>").
AGENT_ROOM_PORT=3000

# Path to the SQLite database file (directories are created if missing).
AGENT_ROOM_DB=./data/clausroom.sqlite

# Directory where uploaded artifacts are stored on disk.
AGENT_ROOM_ARTIFACT_DIR=./data/artifacts

# Absolute cap for a single artifact upload, in bytes (default 100 MiB).
AGENT_ROOM_MAX_UPLOAD_BYTES=104857600

# Agent uploads larger than this (bytes) require an approved approval (default 1 MiB).
AGENT_ROOM_REQUIRE_APPROVAL_BYTES=1048576

# Artifact retention in days (float, default 30). Expired artifact files are
# swept from disk (metadata rows are kept). 0 = immediate expiry (tests);
# negative or the literal string "off" disables expiry entirely.
AGENT_ROOM_ARTIFACT_RETENTION_DAYS=30

# Per-room cap on the total bytes of live (non-deleted) artifacts (default 1 GiB).
# Uploads that would exceed it are rejected with 413 quota_exceeded.
AGENT_ROOM_ROOM_STORAGE_BYTES=1073741824

# Sliding expiry for human session tokens, in days (float, default 30). Every
# use refreshes the window, so active sessions never expire; idle ones need a
# fresh invite from the room owner (the server prints a recovery invite on
# restart if the admin locked themselves out).
AGENT_ROOM_SESSION_TTL_DAYS=30

# Max consecutive agent-sent messages in a room before a human must speak (default 3).
AGENT_ROOM_MAX_AUTO_TURNS=3

# Optional: override the directory of the built web UI served at "/".
# Default: <repo>/apps/web/dist
AGENT_ROOM_WEB_DIST=

# Optional: public base URL (e.g. https://agent-room-host.<tailnet>.ts.net)
# shown in UI copy/paste snippets. No trailing slash.
AGENT_ROOM_PUBLIC_BASE_URL=

# Bridge only: the bridge token minted by the room owner (never stored in files;
# referenced from bridge.toml via `token_env`).
AGENT_ROOM_BRIDGE_TOKEN=
