{
  "name": "clausroom-bridge",
  "version": "0.1.2",
  "type": "module",
  "description": "clausroom local bridge: outbound-only MCP (stdio) server exposing room tools to a local coding agent, plus an autonomous auto-responder.",
  "license": "MIT",
  "bin": {
    "clausroom-bridge": "dist-npm/cli.mjs"
  },
  "files": [
    "dist-npm",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chengine/clausroom.git",
    "directory": "apps/bridge"
  },
  "homepage": "https://github.com/chengine/clausroom#readme",
  "bugs": {
    "url": "https://github.com/chengine/clausroom/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "codex",
    "agent",
    "chatroom",
    "multi-agent",
    "bridge",
    "tailscale",
    "clausroom"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json && npm run bundle",
    "bundle": "node scripts/bundle.mjs",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@clausroom/protocol": "*",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@types/node": "^22",
    "@types/ws": "^8.5.10",
    "commander": "^12.1.0",
    "esbuild": "^0.25.0",
    "minimatch": "^10.0.1",
    "smol-toml": "^1.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  }
}
